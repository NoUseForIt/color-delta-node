# Environment Variables - Frontend Production
# Fichier .env pour React (Vite)

# ===== API BACKEND =====
# URL backend API (sans trailing slash)
VITE_API_BASE_URL=http://localhost:5000

# Timeout requêtes API (ms)
VITE_API_TIMEOUT=30000

# ===== FEATURES FLAGS =====
# Activer mode debug console
VITE_DEBUG_MODE=false

# Activer historique itérations
VITE_FEATURE_HISTORY=true

# Activer export multiple formats
VITE_FEATURE_MULTI_EXPORT=false

# ===== UI CONFIGURATION =====
# Nombre max couleurs affichées sans pagination
VITE_MAX_COLORS_DISPLAY=100

# Seuils Delta E alertes
VITE_DELTA_E_WARN=1.5
VITE_DELTA_E_DANGER=2.5

# ===== ANALYTICS (optionnel) =====
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# VITE_SENTRY_DSN=https://xxx@sentry.io/xxx

# ===== BUILD =====
# Base path si deployment sous-dossier
# VITE_BASE_URL=/color-delta/
