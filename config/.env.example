# Environment Variables - Backend Production
# Copier ce fichier en .env et configurer valeurs

# ===== SERVER =====
NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# ===== CORS =====
# Liste origins autorisées (séparées par virgules)
CORS_ORIGINS=http://localhost:3000,https://votre-domaine.com

# ===== UPLOAD =====
# Taille max fichier upload (bytes)
MAX_FILE_SIZE=10485760

# Dossier stockage temporaire uploads
UPLOAD_DIR=./uploads

# ===== LOGS =====
# Niveau logs : error, warn, info, debug
LOG_LEVEL=info

# Fichier logs (optionnel)
LOG_FILE=./logs/app.log

# ===== SÉCURITÉ =====
# Activer Helmet security headers
HELMET_ENABLED=true

# Rate limiting (requêtes par minute par IP)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ===== PERFORMANCE =====
# Timeout requêtes API (ms)
API_TIMEOUT=30000

# Activer compression gzip
COMPRESSION_ENABLED=true

# ===== MONITORING =====
# Health check interval (ms)
HEALTH_CHECK_INTERVAL=30000

# ===== DATABASE (si future Phase 6) =====
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=color_delta
# DB_USER=admin
# DB_PASSWORD=changeme

# ===== SMTP EMAIL (alertes futures) =====
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-password
